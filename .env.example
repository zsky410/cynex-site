# ---- Core ----
NODE_ENV=development

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://cynex:cynex@localhost:5432/cynex?schema=public

# ---- Redis (BullMQ) ----
REDIS_URL=redis://localhost:6379

# ---- API ----
API_PORT=3001
# Public base url of the customer web app (used in emails / payment redirects)
WEB_BASE_URL=http://localhost:3000
ADMIN_BASE_URL=http://localhost:5173

# ---- Auth (JWT) ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=86400
JWT_REFRESH_TTL=1209600

# ---- Secret-at-rest encryption (AES-256-GCM) ----
# 32 random bytes, base64 encoded. Generate: openssl rand -base64 32
ENCRYPTION_KEY=Zm9vYmFyYmF6cXV4Zm9vYmFyYmF6cXV4Zm9vYmFyYmE=

# ---- payOS ----
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=http://localhost:3000/checkout/return
PAYOS_CANCEL_URL=http://localhost:3000/checkout/cancel

# ---- Resend (email) ----
RESEND_API_KEY=
EMAIL_FROM="Cynex <noreply@cynex.local>"

# ---- Cloudflare R2 ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cynex
R2_PUBLIC_BASE_URL=
R2_ENDPOINT=

# ---- Sentry (optional) ----
SENTRY_DSN=

# ---- Web (Next public) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
