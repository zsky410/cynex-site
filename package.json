{
  "name": "cynex",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm -F @cynex/db generate",
    "db:migrate": "pnpm -F @cynex/db migrate",
    "db:seed": "pnpm -F @cynex/db seed",
    "db:studio": "pnpm -F @cynex/db studio"
  },
  "devDependencies": {
    "turbo": "^2.5.5",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "argon2",
      "esbuild",
      "sharp",
      "msgpackr-extract"
    ],
    "overrides": {
      "ioredis": "5.10.1",
      "@types/react": "^19.0.7",
      "@types/react-dom": "^19.0.3"
    }
  }
}
